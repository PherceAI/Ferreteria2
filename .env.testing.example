# .env.testing.example
#
# Copia este archivo a .env.testing antes de correr la suite de integracion:
#     cp .env.testing.example .env.testing
#
# La suite opt-in (composer test:integration) lee estas variables para
# apuntar a Postgres + Redis reales locales. No se versiona .env.testing
# para que cada desarrollador ajuste credenciales a su entorno.

APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

BCRYPT_ROUNDS=4

# --- Postgres real ----------------------------------------------------
# Usa una base dedicada (ferreteria_test) para que RefreshDatabase no pise
# el entorno de desarrollo. Los roles ferreteria_app / ferreteria_etl
# deben existir (ver docker/postgres/init/02-sync-existing-volume.sql).
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ferreteria_test
DB_USERNAME=ferreteria_app
DB_PASSWORD=
DB_SEARCH_PATH=public,pherce_intel,tini_raw

DB_ETL_HOST=127.0.0.1
DB_ETL_PORT=5432
DB_ETL_DATABASE=ferreteria_test
DB_ETL_USERNAME=ferreteria_etl
DB_ETL_PASSWORD=
DB_ETL_SEARCH_PATH=tini_raw,public

# --- Redis real -------------------------------------------------------
# DBs 10-13 reservadas para testing para no pisar dev (1-4).
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_CACHE_DB=10
REDIS_QUEUE_DB=11
REDIS_SESSION_DB=12
REDIS_PULSE_DB=13

CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=queue
SESSION_DRIVER=redis
SESSION_CONNECTION=session
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

# Reverb no se levanta en tests.
BROADCAST_CONNECTION=log

PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false

MAIL_MAILER=array
