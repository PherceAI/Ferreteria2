APP_NAME=Ferreteria
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-dominio.com
ASSET_URL=https://tu-dominio.com
ALLOW_PUBLIC_REGISTRATION=false
TRUSTED_PROXIES=*

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SEARCH_PATH=public,pherce_intel,tini_raw
DB_SSLMODE=prefer

DB_ETL_HOST="${DB_HOST}"
DB_ETL_PORT="${DB_PORT}"
DB_ETL_DATABASE="${DB_DATABASE}"
DB_ETL_USERNAME="${DB_USERNAME}"
DB_ETL_PASSWORD="${DB_PASSWORD}"
DB_ETL_SEARCH_PATH=tini_raw,public
DB_ETL_SSLMODE="${DB_SSLMODE}"

SESSION_DRIVER=redis
SESSION_CONNECTION=session
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public

REDIS_CLIENT=phpredis
REDIS_HOST=
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_CONNECTION=queue
REDIS_QUEUE_DB=2
REDIS_SESSION_DB=3
REDIS_PULSE_DB=4

RUN_MIGRATIONS=true
QUEUE_WORKER=queue
SCHEDULER_ENABLED=true
REVERB_ENABLED=false

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

PULSE_ENABLED=true
PULSE_INGEST_DRIVER=redis
PULSE_REDIS_CONNECTION=pulse
PULSE_CACHE_DRIVER=redis
TELESCOPE_ENABLED=false

OBSERVABILITY_EMAILS=
MAIL_MAILER=log
MAIL_FROM_ADDRESS=notificaciones@tu-dominio.com
MAIL_FROM_NAME="${APP_NAME}"

BACKUP_ARCHIVE_PASSWORD=
BACKUP_NOTIFICATIONS_EMAILS=

VAPID_SUBJECT="mailto:${MAIL_FROM_ADDRESS}"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

UBIKA_DEVICES_URL=https://plataforma.ubikarecuador.com/api/get_devices
UBIKA_USER_API_HASH=

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI="${APP_URL}/purchasing/gmail/callback"
GMAIL_POLL_QUERY="has:attachment filename:xml is:unread"
